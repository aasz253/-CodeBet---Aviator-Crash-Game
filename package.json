{
  "name": "codebet",
  "version": "1.0.0",
  "description": "Aviator-inspired crash game simulator",
  "main": "server/src/index.js",
  "scripts": {
    "server": "node server/src/index.js",
    "client": "cd client && npm start",
    "analytics": "cd analytics && npm start",
    "install-all": "npm install && cd client && npm install && cd ../analytics && npm install",
    "dev": "concurrently \"npm run server\" \"npm run client\""
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "socket.io": "^4.7.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
